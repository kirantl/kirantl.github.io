---
import type { GetStaticPaths } from 'astro';
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import { Icon } from 'astro-icon/components';
import { getLangFromUrl } from '~/i18n/utils';
import { useTranslations } from '~/i18n/translations';

export const getStaticPaths = (() => {
  return [{ params: { lang: 'en' } }, { params: { lang: 'fr' } }];
}) satisfies GetStaticPaths;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const page = t.projects.recoEngines;

const metadata = {
  title: page.hero.title,
};
---

<Layout metadata={metadata}>
  <Hero tagline={page.hero.tagline}>
    <Fragment slot="title">{page.hero.title}</Fragment>
    <Fragment slot="subtitle">{page.hero.subtitle}</Fragment>
  </Hero>

  <!-- Quick nav with icons -->
  <section class="relative -mt-4 mb-8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <nav class="flex flex-wrap gap-2 justify-center">
        {page.items.map((item: any) => (
          <a
            href={`#${item.id}`}
            class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300 border border-blue-200 dark:border-blue-800 hover:bg-blue-100 dark:hover:bg-blue-900/40 transition-colors"
            data-accordion-trigger={item.id}
          >
            <Icon name={item.icon} class="w-4 h-4" />
            {item.title}
          </a>
        ))}
      </nav>
    </div>
  </section>

  <!-- Accordion project articles -->
  <section class="mb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      {page.items.map((item: any) => (
        <article id={item.id} class="scroll-mt-24 mb-4">
          <div class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 shadow-sm hover:shadow-md transition-shadow overflow-hidden">
            {/* Accordion header — always visible */}
            <button
              type="button"
              class="accordion-toggle w-full flex items-center gap-4 p-6 sm:p-8 text-left cursor-pointer"
              data-target={item.id}
              aria-expanded="false"
            >
              <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center">
                <Icon name={item.icon} class="w-5 h-5 text-blue-600 dark:text-blue-400" />
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wider mb-0.5">{item.tagline}</p>
                <h2 class="text-xl font-bold text-gray-900 dark:text-white truncate">{item.title}</h2>
              </div>
              <Icon name="tabler:chevron-down" class="accordion-chevron w-5 h-5 text-gray-400 dark:text-gray-500 transition-transform duration-300 flex-shrink-0" />
            </button>

            {/* Accordion content — hidden by default */}
            <div class="accordion-content hidden" data-panel={item.id}>
              <div class="px-6 sm:px-8 pb-6 sm:pb-8 border-t border-gray-100 dark:border-gray-700 pt-6">
                <div class="prose dark:prose-invert max-w-none mb-6" set:html={item.content} />
                <div class="flex flex-wrap gap-2">
                  {item.items.map((tech: any) => (
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300">
                      {tech.title}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>

<script>
  function initAccordion() {
    // Accordion toggle buttons
    document.querySelectorAll('.accordion-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const targetId = (btn as HTMLElement).dataset.target;
        const panel = document.querySelector(`[data-panel="${targetId}"]`);
        const chevron = btn.querySelector('.accordion-chevron');
        const isOpen = !panel?.classList.contains('hidden');

        // Close all panels
        document.querySelectorAll('.accordion-content').forEach((p) => p.classList.add('hidden'));
        document.querySelectorAll('.accordion-toggle').forEach((b) => {
          b.setAttribute('aria-expanded', 'false');
          b.querySelector('.accordion-chevron')?.classList.remove('rotate-180');
        });

        // Toggle clicked panel
        if (!isOpen && panel) {
          panel.classList.remove('hidden');
          btn.setAttribute('aria-expanded', 'true');
          chevron?.classList.add('rotate-180');
        }
      });
    });

    // Nav pill triggers
    document.querySelectorAll('[data-accordion-trigger]').forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = (link as HTMLElement).dataset.accordionTrigger;
        const btn = document.querySelector(`.accordion-toggle[data-target="${targetId}"]`) as HTMLElement;
        if (btn) {
          btn.click();
          setTimeout(() => {
            document.getElementById(targetId!)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }, 100);
        }
      });
    });

    // Open from URL hash
    const hash = window.location.hash.slice(1);
    if (hash) {
      const btn = document.querySelector(`.accordion-toggle[data-target="${hash}"]`) as HTMLElement;
      if (btn) btn.click();
    }
  }

  initAccordion();
  document.addEventListener('astro:after-swap', initAccordion);
</script>
