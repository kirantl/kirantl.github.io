---
import type { GetStaticPaths } from 'astro';
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import { Icon } from 'astro-icon/components';
import { getLangFromUrl } from '~/i18n/utils';
import { useTranslations } from '~/i18n/translations';

export const getStaticPaths = (() => {
  return [{ params: { lang: 'en' } }, { params: { lang: 'fr' } }];
}) satisfies GetStaticPaths;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const page = t.projects.recoEngines;

const metadata = {
  title: page.hero.title,
};
---

<Layout metadata={metadata}>
  <Hero tagline={page.hero.tagline}>
    <Fragment slot="title">{page.hero.title}</Fragment>
    <Fragment slot="subtitle">{page.hero.subtitle}</Fragment>
  </Hero>

  <!-- Quick nav for sub-projects -->
  <section class="relative -mt-4 mb-8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <nav class="flex flex-wrap gap-2 justify-center">
        {page.items.map((item: any) => (
          <a
            href={`#${item.id}`}
            class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300 border border-blue-200 dark:border-blue-800 hover:bg-blue-100 dark:hover:bg-blue-900/40 transition-colors"
          >
            <Icon name="tabler:arrow-down" class="w-3.5 h-3.5" />
            {item.title}
          </a>
        ))}
      </nav>
    </div>
  </section>

  <!-- Project articles -->
  <section class="mb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      {page.items.map((item: any, index: number) => (
        <article id={item.id} class="scroll-mt-24 mb-12 last:mb-0">
          <div class="relative rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 p-6 sm:p-8 shadow-sm hover:shadow-md transition-shadow">
            {/* Tagline */}
            <p class="text-sm font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wider mb-2">{item.tagline}</p>

            {/* Title */}
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">{item.title}</h2>

            {/* Content */}
            <div class="prose prose-lg dark:prose-invert max-w-none mb-6" set:html={item.content} />

            {/* Tech tags */}
            <div class="flex flex-wrap gap-2">
              {item.items.map((tech: any) => (
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300">
                  {tech.title}
                </span>
              ))}
            </div>
          </div>

          {/* Connector line between articles */}
          {index < page.items.length - 1 && (
            <div class="flex justify-center py-4">
              <div class="w-px h-8 bg-gray-200 dark:bg-gray-700"></div>
            </div>
          )}
        </article>
      ))}
    </div>
  </section>
</Layout>
