---
import type { GetStaticPaths } from 'astro';
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import { Icon } from 'astro-icon/components';
import { getLangFromUrl } from '~/i18n/utils';
import { useTranslations } from '~/i18n/translations';

export const getStaticPaths = (() => {
  return [{ params: { lang: 'en' } }, { params: { lang: 'fr' } }];
}) satisfies GetStaticPaths;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const metadata = {
  title: t.certifications.hero.title,
};

const certItems = t.certifications.timeline.items as Array<{
  title: string;
  description: string;
  icon: string;
  link?: string;
  badge?: string;
}>;

// Parse issuer and year from description (format: "Issuer · Year\nDetails")
function parseDescription(desc: string) {
  const lines = desc.split('\n');
  const firstLine = lines[0] || '';
  const details = lines.slice(1).join(' ').trim();
  const [issuer, year] = firstLine.split(' · ').map((s) => s.trim());
  return { issuer: issuer || '', year: year || '', details };
}

// Provider color mapping
function getProviderStyle(issuer: string) {
  if (issuer.toLowerCase().includes('google'))
    return { bg: 'bg-blue-50 dark:bg-blue-900/20', border: 'border-blue-300 dark:border-blue-700', badge: 'bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300', iconBg: 'bg-blue-100 dark:bg-blue-900/50', iconColor: 'text-blue-600 dark:text-blue-400', line: 'bg-blue-200 dark:bg-blue-800' };
  if (issuer.toLowerCase().includes('astronomer'))
    return { bg: 'bg-purple-50 dark:bg-purple-900/20', border: 'border-purple-300 dark:border-purple-700', badge: 'bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300', iconBg: 'bg-purple-100 dark:bg-purple-900/50', iconColor: 'text-purple-600 dark:text-purple-400', line: 'bg-purple-200 dark:bg-purple-800' };
  if (issuer.toLowerCase().includes('datacamp'))
    return { bg: 'bg-green-50 dark:bg-green-900/20', border: 'border-green-300 dark:border-green-700', badge: 'bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300', iconBg: 'bg-green-100 dark:bg-green-900/50', iconColor: 'text-green-600 dark:text-green-400', line: 'bg-green-200 dark:bg-green-800' };
  if (issuer.toLowerCase().includes('python'))
    return { bg: 'bg-yellow-50 dark:bg-yellow-900/20', border: 'border-yellow-300 dark:border-yellow-700', badge: 'bg-yellow-100 dark:bg-yellow-900/40 text-yellow-700 dark:text-yellow-300', iconBg: 'bg-yellow-100 dark:bg-yellow-900/50', iconColor: 'text-yellow-600 dark:text-yellow-400', line: 'bg-yellow-200 dark:bg-yellow-800' };
  if (issuer.toLowerCase().includes('coursera'))
    return { bg: 'bg-sky-50 dark:bg-sky-900/20', border: 'border-sky-300 dark:border-sky-700', badge: 'bg-sky-100 dark:bg-sky-900/40 text-sky-700 dark:text-sky-300', iconBg: 'bg-sky-100 dark:bg-sky-900/50', iconColor: 'text-sky-600 dark:text-sky-400', line: 'bg-sky-200 dark:bg-sky-800' };
  return { bg: 'bg-gray-50 dark:bg-gray-800/40', border: 'border-gray-300 dark:border-gray-600', badge: 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300', iconBg: 'bg-gray-100 dark:bg-gray-800', iconColor: 'text-gray-600 dark:text-gray-400', line: 'bg-gray-200 dark:bg-gray-700' };
}

const verifyText = lang === 'en' ? 'Verify Credential' : 'Vérifier le certificat';
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero tagline={t.certifications.hero.tagline}>
    <Fragment slot="title">
      {t.certifications.hero.title}
    </Fragment>
    <Fragment slot="subtitle">
      {t.certifications.hero.subtitle}
    </Fragment>
  </Hero>

  <!-- Certification Timeline -->
  <section class="relative -mt-8 mb-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="relative">
        {certItems.map((item, index) => {
          const { issuer, year, details } = parseDescription(item.description);
          const style = getProviderStyle(issuer);
          const isLast = index === certItems.length - 1;
          return (
            <div class="relative flex gap-6 pb-12 last:pb-0 group">
              {/* Timeline spine: icon + connecting line */}
              <div class="flex flex-col items-center">
                <div class={`relative z-10 flex items-center justify-center w-12 h-12 rounded-full border-2 ${style.border} ${style.iconBg} shadow-sm group-hover:shadow-md group-hover:scale-110 transition-all duration-300`}>
                  <Icon name={item.icon || 'tabler:certificate'} class={`w-6 h-6 ${style.iconColor}`} />
                </div>
                {!isLast && (
                  <div class={`w-0.5 flex-1 mt-2 ${style.line} transition-colors duration-300`} />
                )}
              </div>

              {/* Content card */}
              <div class={`flex-1 rounded-xl border ${style.border} ${style.bg} p-5 shadow-sm hover:shadow-lg transition-all duration-300 -mt-1`}>
                <div class="flex gap-4">
                  {/* Badge image */}
                  {item.badge && (
                    <a href={item.link || '#'} target="_blank" rel="noopener noreferrer" class="flex-shrink-0">
                      <img
                        src={item.badge}
                        alt={`${item.title} badge`}
                        class="w-20 h-20 rounded-lg object-contain hover:scale-105 transition-transform duration-300"
                        loading="lazy"
                      />
                    </a>
                  )}
                  <div class="flex-1 min-w-0">
                    {/* Header row: year badge + issuer */}
                    <div class="flex items-center gap-3 mb-2">
                      <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold ${style.badge}`}>
                        {year}
                      </span>
                      <span class={`text-sm font-semibold ${style.iconColor}`}>
                        {issuer}
                      </span>
                    </div>

                    {/* Title */}
                    <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-1.5 leading-snug">
                      {item.title}
                    </h3>

                    {/* Description */}
                    <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-3">
                      {details}
                    </p>

                    {/* Verify link */}
                    {item.link && (
                      <a
                        href={item.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class={`inline-flex items-center gap-1.5 text-sm font-semibold ${style.iconColor} hover:underline`}
                      >
                        <Icon name="tabler:external-link" class="w-4 h-4" />
                        {verifyText}
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
</Layout>
