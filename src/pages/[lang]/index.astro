---
import type { GetStaticPaths } from 'astro';
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import { getLangFromUrl } from '~/i18n/utils';
import { useTranslations } from '~/i18n/translations';

export const getStaticPaths = (() => {
  return [{ params: { lang: 'en' } }, { params: { lang: 'fr' } }];
}) satisfies GetStaticPaths;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const metadata = {
  title: lang === 'en' ? 'Kiran Tirumale — Data Scientist' : 'Kiran Tirumale — Data Scientist',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: t.home.hero.cta,
        href: `/${lang}/projects/recommendation-engines`,
        icon: 'tabler:arrow-right',
      },
      {
        text: t.home.hero.ctaSecondary,
        href: `/${lang}/about`,
      },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Kiran Tirumale' }}
  >
    <Fragment slot="tagline">{t.home.hero.tagline}</Fragment>
    <Fragment slot="title">
      <Fragment set:html={t.home.hero.title} />
    </Fragment>
    <Fragment slot="subtitle">
      {t.home.hero.subtitle}
    </Fragment>
  </Hero>

  <!-- Thoughts on Gen AI -->
  <section class="relative py-12 md:py-16 lg:py-20">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-purple-50/30 to-transparent dark:via-purple-900/10"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6">
      <div class="relative bg-white/60 dark:bg-slate-800/60 backdrop-blur-sm rounded-2xl border border-gray-200/60 dark:border-slate-700/60 p-8 md:p-12 shadow-sm">
        <!-- Decorative quote mark -->
        <div class="absolute -top-4 left-8 md:left-12">
          <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-purple-100 dark:bg-purple-900/40 text-purple-600 dark:text-purple-400 text-lg font-serif font-bold">"</span>
        </div>

        <!-- Label + Date -->
        <div class="flex flex-wrap items-center gap-3 mb-6">
          <span class="inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-purple-600 dark:text-purple-400">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
            {t.home.thoughts.label}
          </span>
          <span class="text-xs text-gray-400 dark:text-gray-500">·</span>
          <span class="text-xs text-gray-400 dark:text-gray-500">{t.home.thoughts.date}</span>
        </div>

        <!-- Quote paragraphs -->
        <div class="space-y-4">
          {t.home.thoughts.paragraphs.map((paragraph: string, i: number) => (
            <p class:list={[
              'text-base md:text-lg leading-relaxed',
              i === t.home.thoughts.paragraphs.length - 1
                ? 'text-gray-800 dark:text-gray-200 font-medium'
                : 'text-gray-600 dark:text-gray-400',
            ]}>
              {i === t.home.thoughts.paragraphs.length - 1 ? (
                <Fragment>
                  <em>{paragraph}</em>
                </Fragment>
              ) : paragraph}
            </p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <Features2
    tagline={t.home.featuredProjects.tagline}
    title={t.home.featuredProjects.title}
    subtitle={t.home.featuredProjects.subtitle}
    items={[
      {
        title: lang === 'en' ? 'Recommendation Engines' : 'Moteurs de Recommandation',
        description: lang === 'en' ? '4 recommendation engines for Auchan.fr replacing a costly external solution, generating €1M+ in incremental revenue.' : '4 moteurs de recommandation pour Auchan.fr remplaçant une solution externe coûteuse, générant +1M€ de CA additionnel.',
        icon: 'tabler:shopping-cart',
        callToAction: { text: lang === 'en' ? 'Learn more' : 'En savoir plus', href: `/${lang}/projects/recommendation-engines` },
      },
      {
        title: lang === 'en' ? 'Optimization Techniques' : 'Techniques d\'Optimisation',
        description: lang === 'en' ? 'Predictive models to optimize store surface allocation and maximize revenue per square meter.' : 'Modèles prédictifs pour optimiser l\'allocation de surface magasin et maximiser le CA au mètre carré.',
        icon: 'tabler:chart-line',
        callToAction: { text: lang === 'en' ? 'Learn more' : 'En savoir plus', href: `/${lang}/projects/optimization-techniques` },
      },
      {
        title: lang === 'en' ? 'Gen AI Applications' : 'Applications Gen AI',
        description: lang === 'en' ? 'LLM-powered solutions: automated verbatim analysis, product label extraction, and conversational AI interfaces.' : 'Solutions LLM : analyse automatisée de verbatims, extraction d\'étiquettes, interfaces IA conversationnelles.',
        icon: 'tabler:brain',
        callToAction: { text: lang === 'en' ? 'Learn more' : 'En savoir plus', href: `/${lang}/projects/gen-ai-applications` },
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>
</Layout>
