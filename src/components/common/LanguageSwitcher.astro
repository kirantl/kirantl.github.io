---
import { getLangFromUrl, getLocalizedPath } from '~/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;
const enPath = getLocalizedPath(currentPath, 'en');
const frPath = getLocalizedPath(currentPath, 'fr');
---

<div class="flex items-center gap-1">
  <a
    href={enPath}
    class:list={[
      'flex items-center gap-1 px-2 py-1 rounded-md text-xs font-medium transition-colors duration-200',
      lang === 'en'
        ? 'bg-primary/10 text-primary dark:bg-primary/20 dark:text-white ring-1 ring-primary/30'
        : 'text-muted hover:bg-gray-100 dark:hover:bg-gray-700 hover:text-gray-900 dark:hover:text-white',
    ]}
    aria-label="English"
    aria-current={lang === 'en' ? 'true' : undefined}
  >
    <img src="/flags/gb.svg" alt="" width="18" height="12" class="w-[18px] h-[12px] rounded-[2px]" />
    <span class="hidden sm:inline">EN</span>
  </a>
  <a
    href={frPath}
    class:list={[
      'flex items-center gap-1 px-2 py-1 rounded-md text-xs font-medium transition-colors duration-200',
      lang === 'fr'
        ? 'bg-primary/10 text-primary dark:bg-primary/20 dark:text-white ring-1 ring-primary/30'
        : 'text-muted hover:bg-gray-100 dark:hover:bg-gray-700 hover:text-gray-900 dark:hover:text-white',
    ]}
    aria-label="Français"
    aria-current={lang === 'fr' ? 'true' : undefined}
  >
    <img src="/flags/fr.svg" alt="" width="18" height="12" class="w-[18px] h-[12px] rounded-[2px]" />
    <span class="hidden sm:inline">FR</span>
  </a>
</div>
